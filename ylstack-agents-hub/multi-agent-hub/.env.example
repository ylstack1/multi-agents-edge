# ── Minimal Environment Variables ──────────────────────────────
# Most configuration is now done through the App Settings UI.
# Only Cloudflare bindings and essential secrets need env vars.

# Web UI Session Secret (required)
SESSION_SECRET=your-session-secret-change-in-production

# Legacy API Keys (optional — set via App Settings UI instead)
# Go to Settings > Providers in the web UI to configure API keys,
# base URLs, models, and provider enable/disable for:
#   OpenAI, Anthropic, Google, DeepSeek, Grok, OpenRouter
# These env vars are only used as fallback defaults:
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Cloudflare (for edge deployment — required for wrangler)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# Telegram (optional — configure in App Settings > Telegram tab)
# TELEGRAM_BOT_TOKEN=your-bot-token

# MCP Server endpoints (comma-separated — configure in App UI)
# MCP_SERVER_URLS=https://mcp.example.com/sse